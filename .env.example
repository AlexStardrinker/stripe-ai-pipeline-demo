# Copy this file to `.env` and fill in your credentials.
# The demo runs without any of these — they are only needed to
# switch from sample-data mode to live integration.

# Anthropic — used by automate.py to call Claude for categorization.
# Get one from https://console.anthropic.com
ANTHROPIC_API_KEY=

# Stripe — replace the CSV loader with stripe.Charge.list()
# Use test mode key for development.
STRIPE_SECRET_KEY=

# Slack — incoming webhook URL for the channel that should receive the digest.
# https://api.slack.com/messaging/webhooks
SLACK_WEBHOOK_URL=

# Google Sheets — path to a service-account JSON key with edit access
# on the target sheet. https://docs.gspread.org/en/latest/oauth2.html
GOOGLE_SERVICE_ACCOUNT_FILE=
GOOGLE_SHEET_NAME=Finance Daily
